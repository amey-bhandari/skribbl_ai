# Server settings
PORT=3001
NODE_ENV=development
AI_PROVIDER=local_doodle

# Google Vision authentication
# Use one of the two options below.
GOOGLE_VISION_API_KEY=your_google_vision_api_key_here
# GOOGLE_APPLICATION_CREDENTIALS=C:\path\to\service-account.json

# Local doodle classifier
DOODLE_SERVICE_URL=http://127.0.0.1:8008

# Gameplay tuning
ROUND_DURATION_SECONDS=30
GUESS_INTERVAL_SECONDS=5
INTERMISSION_SECONDS=5
ROOM_IDLE_TTL_MINUTES=30
VISION_MIN_CONFIDENCE=0.70
MAX_VISION_LABELS=5
VISION_TIMEOUT_MS=8000
