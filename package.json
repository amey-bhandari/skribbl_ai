{
  "name": "skribbl-ai",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:core": "concurrently -n server,web -c cyan,yellow \"npm:dev -w @skribbl-ai/server\" \"npm:dev -w @skribbl-ai/web\"",
    "dev": "concurrently -n doodle,server,web -c magenta,cyan,yellow \"npm:dev:doodle-service\" \"npm:dev -w @skribbl-ai/server\" \"npm:dev -w @skribbl-ai/web\"",
    "dev:doodle-service": "powershell -ExecutionPolicy Bypass -File ./scripts/start-doodle-service.ps1",
    "dev:server:local-ai": "cross-env AI_PROVIDER=local_doodle npm run dev -w @skribbl-ai/server",
    "dev:local-ai": "concurrently -n doodle,server,web -c magenta,cyan,yellow \"npm:dev:doodle-service\" \"npm:dev:server:local-ai\" \"npm:dev -w @skribbl-ai/web\"",
    "doodle:build": "python services/doodle_classifier/scripts/build_prototypes.py",
    "build": "npm run build -w @skribbl-ai/shared && npm run build -w @skribbl-ai/server && npm run build -w @skribbl-ai/web",
    "test": "npm run test --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "cross-env": "^10.0.0"
  }
}
